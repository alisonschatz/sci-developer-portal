{
  "name": "sci-developer-portal",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run verify && npm run build:content && vite build",
    "preview": "vite preview",
    "verify": "node scripts/verify.js",
    "clean": "node scripts/clean.js",
    "test": "node --test",
    "env": "node scripts/env.js",
    "api:new": "node scripts/new-api.js",
    "api:fetch": "node --env-file-if-exists=.env scripts/fetch.js production",
    "api:fetch:hml": "node --env-file-if-exists=.env scripts/fetch.js homolog",
    "build:content": "node --env-file-if-exists=.env scripts/build-content.js production",
    "build:content:hml": "node --env-file-if-exists=.env scripts/build-content.js homolog",
    "api:sync": "npm run api:fetch && npm run build:content",
    "api:sync:hml": "npm run api:fetch:hml && npm run build:content:hml"
  },
  "dependencies": {
    "@scalar/api-reference": "^1.62.7",
    "@unhead/vue": "^2.1.4",
    "js-yaml": "^4.1.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.0.0"
  }
}